# Copy to .env.prod and fill in real values before running the prod compose overlay.
# Never commit the real .env.prod to git.

# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_HEX_STRING

# Public URL the app is served at — must match CORS and frontend NEXT_PUBLIC_API_URL
PUBLIC_URL=https://ops.brightsolarpower.co.za
CORS_ORIGINS=https://ops.brightsolarpower.co.za
